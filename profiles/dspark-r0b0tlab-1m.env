# DSpark-r0b0tlab 1M operating profile.
# Requires host prep: stop/disable gdm3 on participating GB10 nodes before launch.

MAX_MODEL_LEN=1048576
MAX_NUM_SEQS=2
MAX_NUM_BATCHED_TOKENS=8192
GPU_MEMORY_UTILIZATION=0.88
MTP_NUM_TOKENS=5

# Keep the proven native DSpark path.
VLLM_DSPARK_CONFIDENCE_SCHEDULER=off
VLLM_DSPARK_CONFIDENCE_THRESHOLD=0.0
VLLM_DSPARK_FUSED_MARKOV_ARGMAX=0
VLLM_DSPARK_LOCAL_ARGMAX=1
VLLM_DSPARK_GPU_REJECTED_CONTEXT_MASK=1
VLLM_DSPARK_REPLICATE_MARKOV_W1=1
VLLM_DSPARK_REFERENCE_KV_QUANT_DEQUANT=0

# Required for max_model_len above default guardrails.
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1

# Expected evidence after launch:
# - /v1/models reports max_model_len=1048576
# - GPU KV cache size around 3.42M tokens
# - Maximum concurrency for 1,048,576 tokens/request around 3.26x
# - Native markers: DeepSeekV4DSparkModel, nvfp4_ds_mla, B12X, DeepGEMM, NCCL IB
